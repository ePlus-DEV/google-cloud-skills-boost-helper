# Example environment variables for google-cloud-skills-boost-helper
# Replace the placeholder values with your real configuration when running locally

# GraphQL / API
WXT_API_URL=https://domain-api.com/
WXT_API_KEY=your_publication_id_or_api_key

# Arcade API
WXT_ARCADE_POINT_URL=https://arcade.example.com/point

# Firebase configuration (optional)
WXT_FIREBASE_API_KEY=your_firebase_api_key
WXT_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
WXT_FIREBASE_PROJECT_ID=your-firebase-project-id
WXT_FIREBASE_STORAGE_BUCKET=your-app.appspot.com
WXT_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
WXT_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Remote Config timings (ms)
WXT_FIREBASE_FETCH_INTERVAL_MS=900000
WXT_FIREBASE_FETCH_TIMEOUT_MS=60000

# Facilitator Program
WXT_COUNTDOWN_DEADLINE_FACILITATOR="2026-06-30T23:59:59+05:30"
WXT_COUNTDOWN_ENABLED_FACILITATOR=false
# Arcade Program
WXT_COUNTDOWN_DEADLINE_ARCADE=2026-06-30T23:59:59+05:30
WXT_COUNTDOWN_ENABLED_ARCADE=true
# Set true in release builds to force Firebase Remote Config for arcade_milestones.
WXT_FORCE_REMOTE_CONFIG=false
WXT_ARCADE_MILESTONES='[{"points":50,"league":"Arcade Trooper","slots":6000,"spotsLeft":6000},{"points":75,"league":"Arcade Ranger","slots":4000,"spotsLeft":4000},{"points":95,"league":"Arcade Champion","slots":3000,"spotsLeft":3000},{"points":120,"league":"Arcade Legend","slots":2500,"spotsLeft":2500}]'
